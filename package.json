{
  "name": "lawyer-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@lawyer-ai/client\" \"npm run dev --workspace=@lawyer-ai/server\"",
    "client": "npm run dev --workspace=@lawyer-ai/client",
    "server": "npm run dev --workspace=@lawyer-ai/server",
    "install-all": "npm install",
    "build": "npm run build --workspace=@lawyer-ai/client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
